generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     String  @id @default(cuid())
  name   String?
  email  String? @unique
  image  String?
  events Event[]
}

model Event {
  id           String  @id
  title        String
  description  String?
  address      String?
  dateISO      String?
  lat          Float
  lng          Float
  createdAtISO String
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAtISO])
  @@index([lat, lng])
  @@index([userId])
}
